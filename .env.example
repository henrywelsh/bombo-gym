# Database
POSTGRES_DB=bombo_gym
POSTGRES_USERNAME=bombo
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
# Non-default to avoid clashes with other local Postgres instances. Inside docker
# the db container still listens on 5432; this is the host-side port mapping.
POSTGRES_PORT=54329

# Google OAuth — from Google Cloud Console
# Authorized redirect URI: ${APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# better-auth session secret — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Comma-separated origins allowed to make authenticated requests (e.g. the Vite dev server).
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

# Public URL of the deployed app (no trailing slash).
# In dev this is the Vite dev server; in prod it's your https domain.
APP_URL=http://localhost:5173
